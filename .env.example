# Playwright CDP endpoint used to connect to Brave/Chromium.
ENDPOINT_URL="http://127.0.0.1:9222"

# Path to the browser executable.
# Currently documented in the env file; the script does not read it yet.
# Windows example: "C:\Program Files\BraveSoftware\Brave-Browser\Application\brave.exe"
EXECUTABLE_PATH=""

# Browser profile directory.
# Windows example: "C:\Users\YOUR_USERNAME\AppData\Local\BraveSoftware\Brave-Browser\User Data"
PROFILE_PATH="C:\Users\YOUR_USERNAME\AppData\Local\BraveSoftware\Brave-Browser\User Data"

# Placed here for anonymity
WEBSITE_URL=""

# Optional exam page URL already filtered to the correct paper and question type.
# Leave blank to navigate manually before starting the script.
TARGET_URL=""

# Output directory for captured screenshots.
# Leave blank to be prompted for a folder name under outputs/.
OUTPUT_DIR=""

# Browser viewport size used for screenshots.
VIEWPORT_WIDTH=1400
VIEWPORT_HEIGHT=900

# Device scale factor for sharper screenshots.
DEVICE_SCALE=2

# Delay in milliseconds after opening the modal before capture.
MODAL_SETTLE_MS=1200